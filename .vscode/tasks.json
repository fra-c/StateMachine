{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PlatformIO: Test",
      "type": "shell",
      "command": "pio test -e native",
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "options": {
        "statusbar": {
          "label": "$(beaker) Pio Test",
