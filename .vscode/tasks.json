    },
    {
      "label": "PlatformIO: Publish",
      "type": "shell",
      "command": "pio pkg publish",
      "problemMatcher": [],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "options": {
        "statusbar": {
          "label": "$(cloud-upload) Pio Publish",
          "tooltip": "Publish PlatformIO package",
          "color": "#d85a00"
        }
      }
    }
  ]
